# Скопируйте этот файл в .env (это делает setup.sh автоматически) и заполните значения.
# .env НЕ коммитится в git (см. .gitignore).

# --- Общие ---
# Публичный IP или домен сервера. Автоопределяется в setup.sh, можно переопределить вручную.
WG_HOST=CHANGE_ME_SERVER_IP

# Часовой пояс для логов/systemd timers
TZ=Europe/Moscow

# --- wg-easy (WireGuard + веб-панель) ---
# bcrypt-хеш пароля панели. Генерируется setup.sh командой:
#   docker run --rm ghcr.io/wg-easy/wg-easy:14 wgpw 'ваш-пароль'
# ВАЖНО: значение обязательно в одинарных кавычках — хэш содержит "$", без кавычек
# bash при source-инге этого файла попытается раскрыть "$2a"/"$12" как позиционные параметры.
PASSWORD_HASH='CHANGE_ME_BCRYPT_HASH'

# Порт самого WireGuard туннеля (UDP, открыт наружу)
WG_PORT=51820

# Порт веб-панели. В docker-compose.yml привязан ТОЛЬКО к 127.0.0.1 — наружу не открыт.
WEB_PORT=51821

# Внутренняя подсеть VPN
WG_DEFAULT_ADDRESS=10.8.0.x

# DNS, который получают клиенты. dnscrypt-proxy запускается в сетевом namespace wg-easy
# (network_mode: service:wg-easy) и слушает на адресе сервера внутри VPN-подсети (обычно 10.8.0.1 — .1 в WG_DEFAULT_ADDRESS).
WG_DEFAULT_DNS=10.8.0.1

# По умолчанию клиентам выдаётся полный туннель на уровне wg-easy;
# реальный split-tunnel (мир минус Россия) применяется поверх в add-client.sh при генерации AllowedIPs.
WG_ALLOWED_IPS=0.0.0.0/0

# Отключить сбор/показ статистики трафика в панели (privacy)
UI_TRAFFIC_STATS=false

# --- Xray (VLESS + Reality, фолбэк для обхода DPI) ---
# Порт Xray (TCP, обычно 443 чтобы не выделяться на фоне HTTPS)
XRAY_PORT=443

# UUID клиента Xray. Генерируется setup.sh (xray uuid) если не задан.
XRAY_UUID=CHANGE_ME_UUID

# X25519 ключи Reality. Генерируются setup.sh (xray x25519).
XRAY_PRIVATE_KEY=CHANGE_ME_PRIVATE_KEY
XRAY_PUBLIC_KEY=CHANGE_ME_PUBLIC_KEY

# Короткий ID Reality (8 hex-символов). Генерируется setup.sh.
XRAY_SHORT_ID=CHANGE_ME_SHORT_ID

# Домен-маскировка Reality (реальный популярный сайт с TLS 1.3, не наш)
XRAY_SNI=www.microsoft.com

# --- Telegram уведомления (опционально, оставьте пустым чтобы отключить) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
