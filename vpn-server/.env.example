# Copy to .env and edit, OR just run ./setup.sh which generates .env for you.
# Any value set here overrides the auto-detected defaults.

# --- Required for unattended installs (otherwise you are prompted) ---
WEB_PASSWORD=change-me-strong-password

# --- Networking (auto-detected if left blank) ---
PUBLIC_IP=
WG_PORT=51820
WEB_PORT=51821

# --- Hardening ---
SSH_PORT=2222          # set to 0 to keep the default port 22
DISABLE_IPV6=true

# --- Obfuscated fallback ---
XRAY_ENABLE=true
XRAY_PORT=443

# --- Telegram notifications (optional) ---
# Create a bot with @BotFather, get the token; get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
