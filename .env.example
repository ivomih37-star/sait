# ===========================================================================
#  РакияКлуб.рф — переменные окружения (скопировать в .env, заполнить)
# ===========================================================================

# --- База данных (PostgreSQL на Beget VPS) ---
DATABASE_URL="postgresql://raki:password@localhost:5432/rakiaclub?schema=public"

# --- Публичный адрес ---
NEXT_PUBLIC_SITE_URL="https://xn--80aaldqfdq.xn--p1ai"   # РакияКлуб.рф (punycode)
APP_BASE_URL="https://xn--80aaldqfdq.xn--p1ai"

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""             # основной бот (TMA + публикации в канал)
TELEGRAM_ADMIN_BOT_TOKEN=""       # отдельный админ-бот для апрува (можно тот же)
TELEGRAM_CHANNEL_ID="@raki_club"  # публичный канал для постов
TELEGRAM_ADMIN_CHAT_ID=""         # chat_id администратора (получает кнопки апрува)
TELEGRAM_WEBHOOK_SECRET=""        # секрет для проверки вебхука
TMA_URL="https://xn--80aaldqfdq.xn--p1ai/tma"

# --- Подпись билетов / magic-link ---
JWT_SECRET=""                     # подпись QR-токенов билетов
MAGIC_LINK_SECRET=""              # подпись magic-link для B2B

# --- AI-генерация контента (Шаг 6) ---
ANTHROPIC_API_KEY=""
# Модель Claude по умолчанию (самая способная — рекомендуется)
AI_MODEL="claude-opus-4-8"
OPENAI_API_KEY=""                 # опциональный фолбэк

# --- Facebook / Meta Graph API ---
FACEBOOK_PAGE_ID=""
FACEBOOK_PAGE_ACCESS_TOKEN=""

# --- Cron / воркер ---
CRON_SECRET=""                    # защита эндпоинта /api/cron/*
NODE_ENV="development"
